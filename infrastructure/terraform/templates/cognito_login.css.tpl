/* Minimalist theme within Cognito branding constraints */

.background-customizable {
  background-color: #010203;
}

.banner-customizable {
  padding: 16px 20px 16px 20px;
  background-color: rgba(57, 255, 20, 0.12);
}

.logo-customizable {
  max-width: 35%;
  max-height: 35%;
  background-color: #010203;
}

.textDescription-customizable {
  padding-top: 12px;
  padding-bottom: 12px;
  display: block;
  font-size: 14px;
  color: #39ff14;
}

.label-customizable {
  font-weight: 400;
  color: #39ff14;
}

.inputField-customizable {
  width: 100%;
  height: 42px;
  color: #39ff14;
  background-color: rgba(0, 10, 0, 0.82);
  border: 2px solid rgba(57, 255, 20, 0.6);
}

.inputField-customizable:focus {
  border-color: #0dccf2;
  outline: 2px;
}

.legalText-customizable {
  font-size: 12px;
  color: rgba(57, 255, 20, 0.6);
}

.submitButton-customizable {
  font-size: 14px;
  font-weight: 700;
  margin: 24px 0 0 0;
  width: 100%;
  height: 48px;
  color: #001900;
  background-color: rgba(57, 255, 20, 0.75);
}

.submitButton-customizable:hover {
  color: #001900;
  background-color: rgba(13, 204, 242, 0.75);
}

.errorMessage-customizable {
  margin: 12px 0 0 0;
  padding: 12px 12px 12px 12px;
  font-size: 12px;
  width: 100%;
  background: rgba(255, 32, 121, 0.1);
  border: 2px solid rgba(255, 32, 121, 0.4);
  color: #ff2079;
  box-sizing: border-box;
}

.redirect-customizable {
  color: #0dccf2;
}

.idpButton-customizable {
  height: 44px;
  width: 100%;
  text-align: center;
  margin-bottom: 12px;
  color: #0dccf2;
  background-color: rgba(0, 10, 0, 0.82);
  border-color: rgba(13, 204, 242, 0.6);
}

.idpButton-customizable:hover {
  color: #001900;
  background-color: rgba(13, 204, 242, 0.7);
}

.idpDescription-customizable {
  padding-top: 8px;
  padding-bottom: 8px;
  display: block;
  font-size: 13px;
  color: rgba(57, 255, 20, 0.8);
}

.socialButton-customizable {
  height: 44px;
  text-align: center;
  width: 100%;
  margin-bottom: 12px;
  color: #001900;
  background-color: rgba(57, 255, 20, 0.8);
}

.passwordCheck-valid-customizable {
  color: #39ff14;
}

.passwordCheck-notValid-customizable {
  color: #ff2079;
}
